# Markdown: ignore every .md except the root README.md (build logs, specs, generated
# reports and per-track notes stay local; the README is the one committed doc).
*.md
!/README.md

# FastF1 download cache — 800MB+, NEVER commit (regenerated by calibrate/ scripts)
calibrate/cache/

# Python
__pycache__/
*.pyc
.pytest_cache/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Node (none needed for the app, but just in case)
node_modules/

# Keep the small data JSONs (data/pace, data/strategies, *.json) — those ARE the value.
